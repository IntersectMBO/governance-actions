  "hashAlgorithm": "blake2b-256",
  "body": {
    "title": "Reduce govActionDeposit to increase testnet governance participation",
    "abstract": "We propose to decrease `govActionDeposit` from 100,000 tada (100000000000 tlovelace) to 1,000 tada (1000000000 tlovelace), on testnets.",
    "motivation": "The testnet faucet gives users 10,000 tada, by reducing the governance action deposit size (`govActionDeposit`) people are able to submit governance actions with the tada provided by the faucet.",
    "rationale": "This change will make it much easier for people to submit governance actions on testnets.\n\n## Authors\n\n* Intersect",
    "onChain": {
      "deposit": "100000000000",
      "reward_account": "stake_test1up4xt9hftul97kwz9wjfuldvf86hcjjcu9833x5rgltly7s9xkkn9",
