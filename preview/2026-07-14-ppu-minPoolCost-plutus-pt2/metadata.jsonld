        "uri": "https://updates.cardano.intersectmbo.org/reports/2025-03-execbudget-memory-10.2/"
      },
      {
        "@type": "Other",
        "label": "Benchmarking Results — Node version 10.3",
        "uri": "https://updates.cardano.intersectmbo.org/reports/2025-05-execbudget-memory-10.3/"
      },
      {
