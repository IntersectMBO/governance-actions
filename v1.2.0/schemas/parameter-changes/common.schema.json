{
    "title": "Intersect Protocol Parameter Change Schema",
    "description": "Schema for Protocol Parameter Change governance actions, aligned with CIP-100/108/116/169 and the shared schemas/parameter-changes/common.jsonld @context.",
    "type": "object",
    "required": ["hashAlgorithm", "authors", "body"],
    "properties": {
        "hashAlgorithm": { "$ref": "#/definitions/hashAlgorithm" },
        "authors":       { "$ref": "#/definitions/authors" },
        "body":          { "$ref": "#/definitions/body" }
    },
    "definitions": {
        "hashAlgorithm": {
            "type": "string",
            "enum": ["blake2b-256"],
            "title": "Hash Algorithm",
            "description": "The algorithm used to authenticate this document externally (CIP-100)"
        },
        "authors": {
            "title": "Authors",
            "description": "The authors of this governance metadata (CIP-100). At least one signing author is required.",
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/definitions/author" }
        },
        "author": {
            "title": "Author",
            "description": "An author endorsing the content of a metadata document (CIP-100).",
            "type": "object",
            "required": ["name", "witness"],
            "properties": {
                "name":    { "type": "string", "minLength": 1, "title": "Name" },
                "witness": { "$ref": "#/definitions/witness" }
            }
        },
        "witness": {
            "title": "Witness",
            "description": "A witness proving that the author endorses the content of the metadata. Both plain ed25519 and CIP-0008 (message-signing) witnesses are accepted.",
            "type": "object",
            "required": ["witnessAlgorithm", "publicKey", "signature"],
            "properties": {
                "witnessAlgorithm": {
                    "title": "Witness Algorithm",
                    "type": "string",
                    "enum": ["ed25519", "CIP-0008"]
                },
                "publicKey": { "title": "Public Key", "type": "string", "minLength": 1 },
                "signature": { "title": "Signature",  "type": "string", "minLength": 1 }
            }
        },
        "body": {
            "title": "Body",
            "description": "The body of the metadata document that is hashed to produce a signature.",
            "type": "object",
            "required": ["title", "abstract", "motivation", "rationale", "onChain"],
            "properties": {
                "title":      { "type": "string", "minLength": 1, "title": "Title",      "description": "A brief introduction to the motivation for the governance action" },
                "abstract":   { "type": "string", "minLength": 1, "title": "Abstract",   "description": "A concise summary of the motivation and rationale for the governance action" },
                "motivation": { "type": "string", "minLength": 1, "title": "Motivation", "description": "Context around the problem being addressed by the on-chain action" },
                "rationale":  { "type": "string", "minLength": 1, "title": "Rationale",  "description": "Explanation of how the governance action addresses the problem outlined in 'motivation'" },
                "onChain":    { "$ref": "#/definitions/onChain" },
                "references": {
                    "type": "array",
                    "title": "References",
                    "items": { "$ref": "#/definitions/reference" }
                }
            }
        },
        "onChain": {
            "title": "On-chain Effect",
            "description": "CIP-116 ProposalProcedure embedded within the body of the action (CIP-169 onChain extension).",
            "type": "object",
            "required": ["deposit", "reward_account", "gov_action"],
            "properties": {
                "deposit": {
                    "type": "string",
                    "pattern": "^[0-9]+$",
                    "title": "Deposit",
                    "description": "Governance action deposit amount in lovelace; CIP-116 UInt64 encoded as a JSON string."
                },
                "reward_account": {
                    "type": "string",
                    "pattern": "^(stake1|stake_test1)[a-zA-Z0-9]+$",
                    "title": "Reward Account",
                    "description": "Bech32-encoded stake address where the deposit is returned; CIP-116 RewardAddress."
                },
                "gov_action": { "$ref": "#/definitions/govAction" }
            }
        },
        "govAction": {
            "title": "Protocol Parameter Change Governance Action",
            "type": "object",
            "required": ["tag", "gov_action_id", "protocol_param_update"],
            "properties": {
                "tag":                   { "type": "string", "const": "parameter_change_action" },
                "gov_action_id":         { "$ref": "#/definitions/govActionId" },
                "protocol_param_update": { "$ref": "#/definitions/protocolParamUpdate" },
                "policy_hash":           { "$ref": "#/definitions/policyHash" }
            }
        },
        "policyHash": {
            "title": "Policy Hash",
            "description": "Optional hash of the guardrails script that constrains this action; CIP-116 ScriptHash (28-byte blake2b-224 hash, hex-encoded).",
            "type": "string",
            "pattern": "^[0-9a-f]{56}$"
        },
        "govActionId": {
            "title": "Governance Action ID",
            "description": "Reference to the previous parameter-change governance action this proposal extends; CIP-116 GovActionId.",
            "type": "object",
            "required": ["transaction_id", "gov_action_index"],
            "properties": {
                "transaction_id": {
                    "type": "string",
                    "pattern": "^[0-9a-fA-F]{64}$",
                    "title": "Transaction Hash",
                    "description": "32-byte hex-encoded transaction hash; CIP-116 TransactionHash."
                },
                "gov_action_index": {
                    "type": "string",
                    "pattern": "^[0-9]+$",
                    "title": "Governance Action Index",
                    "description": "Index of the action within its containing transaction; CIP-116 UInt16 encoded as a JSON string."
                }
            }
        },
        "protocolParamUpdate": {
            "title": "Protocol Parameter Update",
            "description": "The set of protocol parameters being updated; CIP-116 ProtocolParamUpdate. At least one parameter must be specified.",
            "type": "object",
            "minProperties": 1,
            "properties": {
                "minfee_a":                         { "$ref": "#/definitions/uintString" },
                "minfee_b":                         { "$ref": "#/definitions/uintString" },
                "max_block_body_size":              { "$ref": "#/definitions/uintString" },
                "max_tx_size":                      { "$ref": "#/definitions/uintString" },
                "max_block_header_size":            { "$ref": "#/definitions/uintString" },
                "key_deposit":                      { "$ref": "#/definitions/uintString" },
                "pool_deposit":                     { "$ref": "#/definitions/uintString" },
                "max_epoch":                        { "$ref": "#/definitions/uintString" },
                "n_opt":                            { "$ref": "#/definitions/uintString" },
                "pool_pledge_influence":            { "$ref": "#/definitions/unitInterval" },
                "expansion_rate":                   { "$ref": "#/definitions/unitInterval" },
                "treasury_growth_rate":             { "$ref": "#/definitions/unitInterval" },
                "d":                                { "$ref": "#/definitions/unitInterval" },
                "protocol_version":                 { "$ref": "#/definitions/protocolVersion" },
                "min_pool_cost":                    { "$ref": "#/definitions/uintString" },
                "ada_per_utxo_byte":                { "$ref": "#/definitions/uintString" },
                "cost_models":                      { "$ref": "#/definitions/costModels" },
                "execution_costs":                  { "$ref": "#/definitions/exUnitPrices" },
                "max_tx_ex_units":                  { "$ref": "#/definitions/exUnits" },
                "max_block_ex_units":               { "$ref": "#/definitions/exUnits" },
                "max_value_size":                   { "$ref": "#/definitions/uintString" },
                "collateral_percentage":            { "$ref": "#/definitions/uintString" },
                "max_collateral_inputs":            { "$ref": "#/definitions/uintString" },
                "pool_voting_thresholds":           { "$ref": "#/definitions/poolVotingThresholds" },
                "drep_voting_thresholds":           { "$ref": "#/definitions/drepVotingThresholds" },
                "committee_min_size":               { "$ref": "#/definitions/uintString" },
                "committee_max_term_length":        { "$ref": "#/definitions/uintString" },
                "gov_action_lifetime":              { "$ref": "#/definitions/uintString" },
                "gov_action_deposit":               { "$ref": "#/definitions/uintString" },
                "drep_deposit":                     { "$ref": "#/definitions/uintString" },
                "drep_activity":                    { "$ref": "#/definitions/uintString" },
                "min_fee_ref_script_cost_per_byte": { "$ref": "#/definitions/nonnegativeInterval" }
            }
        },
        "uintString": {
            "title": "Unsigned Integer (string-encoded)",
            "description": "A non-negative integer serialised as a JSON string; covers CIP-116 UInt16 / UInt32 / UInt64.",
            "type": "string",
            "pattern": "^[0-9]+$"
        },
        "intString": {
            "title": "Signed Integer (string-encoded)",
            "description": "A signed integer serialised as a JSON string; covers CIP-116 Int128 (used inside cost_models entries).",
            "type": "string",
            "pattern": "^-?[0-9]+$"
        },
        "unitInterval": {
            "title": "Unit Interval",
            "description": "A rational in [0, 1]; CIP-116 UnitInterval.",
            "type": "object",
            "required": ["numerator", "denominator"],
            "properties": {
                "numerator":   { "$ref": "#/definitions/uintString" },
                "denominator": { "$ref": "#/definitions/uintString" }
            }
        },
        "nonnegativeInterval": {
            "title": "Non-negative Interval",
            "description": "A non-negative rational; CIP-116 NonnegativeInterval.",
            "type": "object",
            "required": ["numerator", "denominator"],
            "properties": {
                "numerator":   { "$ref": "#/definitions/uintString" },
                "denominator": { "$ref": "#/definitions/uintString" }
            }
        },
        "protocolVersion": {
            "title": "Protocol Version",
            "description": "CIP-116 ProtocolVersion.",
            "type": "object",
            "required": ["major", "minor"],
            "properties": {
                "major": { "$ref": "#/definitions/uintString" },
                "minor": { "$ref": "#/definitions/uintString" }
            }
        },
        "exUnits": {
            "title": "Execution Units",
            "description": "CIP-116 ExUnits — Plutus memory and step budgets.",
            "type": "object",
            "required": ["mem", "steps"],
            "properties": {
                "mem":   { "$ref": "#/definitions/uintString" },
                "steps": { "$ref": "#/definitions/uintString" }
            }
        },
        "exUnitPrices": {
            "title": "Execution Unit Prices",
            "description": "CIP-116 ExUnitPrices — price per memory unit and per step.",
            "type": "object",
            "required": ["mem_price", "step_price"],
            "properties": {
                "mem_price":  { "$ref": "#/definitions/nonnegativeInterval" },
                "step_price": { "$ref": "#/definitions/nonnegativeInterval" }
            }
        },
        "costModels": {
            "title": "Cost Models",
            "description": "CIP-116 CostModels. Each Plutus version maps to an ordered array of CIP-116 Int128 values (signed integers serialised as JSON strings).",
            "type": "object",
            "minProperties": 1,
            "properties": {
                "plutus_v1": { "type": "array", "items": { "$ref": "#/definitions/intString" } },
                "plutus_v2": { "type": "array", "items": { "$ref": "#/definitions/intString" } },
                "plutus_v3": { "type": "array", "items": { "$ref": "#/definitions/intString" } }
            }
        },
        "poolVotingThresholds": {
            "title": "SPO Voting Thresholds",
            "description": "CIP-116 PoolVotingThresholds.",
            "type": "object",
            "properties": {
                "motion_no_confidence":                     { "$ref": "#/definitions/unitInterval" },
                "committee_normal":                         { "$ref": "#/definitions/unitInterval" },
                "committee_no_confidence":                  { "$ref": "#/definitions/unitInterval" },
                "hard_fork_initiation":                     { "$ref": "#/definitions/unitInterval" },
                "security_relevant_param_voting_threshold": { "$ref": "#/definitions/unitInterval" }
            }
        },
        "drepVotingThresholds": {
            "title": "DRep Voting Thresholds",
            "description": "CIP-116 DRepVotingThresholds.",
            "type": "object",
            "properties": {
                "motion_no_confidence":    { "$ref": "#/definitions/unitInterval" },
                "committee_normal":        { "$ref": "#/definitions/unitInterval" },
                "committee_no_confidence": { "$ref": "#/definitions/unitInterval" },
                "update_constitution":     { "$ref": "#/definitions/unitInterval" },
                "hard_fork_initiation":    { "$ref": "#/definitions/unitInterval" },
                "pp_network_group":        { "$ref": "#/definitions/unitInterval" },
                "pp_economic_group":       { "$ref": "#/definitions/unitInterval" },
                "pp_technical_group":      { "$ref": "#/definitions/unitInterval" },
                "pp_governance_group":     { "$ref": "#/definitions/unitInterval" },
                "treasury_withdrawal":     { "$ref": "#/definitions/unitInterval" }
            }
        },
        "reference": {
            "title": "Reference",
            "description": "A reference to a document",
            "type": "object",
            "required": ["@type", "label", "uri"],
            "properties": {
                "@type": { "type": "string", "enum": ["GovernanceMetadata", "Other"], "title": "Type" },
                "label": { "type": "string", "title": "Label" },
                "uri":   { "type": "string", "title": "URI" },
                "referenceHash": { "$ref": "#/definitions/referenceHash" }
            }
        },
        "referenceHash": {
            "title": "Reference Hash",
            "description": "A hash of a reference document",
            "type": "object",
            "required": ["hashDigest", "hashAlgorithm"],
            "properties": {
                "hashDigest":    { "type": "string", "title": "Hash" },
                "hashAlgorithm": { "$ref": "#/definitions/hashAlgorithm" }
            }
        }
    }
}
